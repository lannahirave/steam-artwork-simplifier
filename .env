# ============================================================
# Toolchain
# ============================================================
# Folder that contains ffmpeg.exe and ffprobe.exe.
FFMPEG_BIN=D:\ffmpeg\bin

# ============================================================
# video_parts_pipeline.py (video -> Steam GIFs)
# ============================================================
# Output mode: workshop (5 slices) or featured (single wide GIF).
GIF_PRESET=workshop

# Workshop layout: number of GIF parts and width of each part (px).
GIF_PARTS=5
GIF_PART_WIDTH=150

# Featured layout: width of the single output GIF (px).
FEATURED_ARTWORK_WIDTH=630

# Starting GIF FPS for first encode pass.
GIF_FPS=15

# Hard lower FPS floor used during recompression attempts.
# Script will not go below this value.
GIF_MIN_FPS=10

# Early size feasibility check before encoding.
GIF_PRECHECK_ENABLED=true

# Precheck model: estimated bytes per pixel-frame (higher = stricter).
GIF_PRECHECK_BPPF=0.10

# Extra tolerance (%) for precheck vs max KB limit.
GIF_PRECHECK_MARGIN_PCT=10

# Parallel part processing.
# 0 = auto (use CPU count / part count).
# How to estimate manually:
# 1) Get logical CPU threads (T) from Task Manager (e.g. Ryzen 5700X => T=16).
# 2) Pick workers (W) based on independent jobs:
#    - workshop preset: up to 5 jobs -> W in [4..5] is typical on 16 threads.
#    - featured preset: only 1 job -> W must be 1.
# 3) Keep total CPU pressure near T:
#    W * FFMPEG_THREADS ~= T (or slightly below).
# 4) Start point formula:
#    W = min(parts, floor(T/3) to floor(T/2))
#    FFMPEG_THREADS = max(1, floor(T / W))
# 5) If CPU is low (<85%), increase W or threads.
#    If system lags/thrashes, reduce W first.
GIF_MAX_WORKERS=0

# Threads per ffmpeg process.
# 0 = auto split across workers.
# Example for T=16, workshop parts=5:
# - W=5 and FFMPEG_THREADS=3  -> 15 effective threads (good saturation).
# - W=4 and FFMPEG_THREADS=4  -> 16 effective threads (also valid).
FFMPEG_THREADS=0

# NVIDIA decode acceleration toggle for ffmpeg input.
# true = enable --use-nvidia behavior by default.
USE_NVIDIA=false

# Workshop GIF limits in KB.
# MAX = hard limit, TARGET = preferred recompression target.
WORKSHOP_MAX_KB=5000
WORKSHOP_TARGET_KB=4500

# Featured GIF limits in KB.
FEATURED_MAX_KB=4500
FEATURED_TARGET_KB=4500

# Apply EOF byte patch to each produced GIF (Steam compatibility workflow).
GIF_HEX_PATCH_ENABLED=true

# EOF patch byte in hex (21 means 0x21).
GIF_HEX_BYTE=21

# ============================================================
# steam_hex_patch.py (standalone EOF patcher)
# ============================================================
# Default byte written to the final file byte.
HEX_DEFAULT_BYTE=21

# Comma-separated extensions targeted by default.
HEX_DEFAULT_EXTENSIONS=.gif,.png,.jpg,.jpeg,.webm,.mp4

# Backup original files before patching.
HEX_BACKUP_ENABLED=true

# ============================================================
# steam_hex_edit_header.py (GIF header width/height edit)
# ============================================================
# Width/height written to GIF header bytes 6-9 by default.
HEX_HEADER_WIDTH=1000
HEX_HEADER_HEIGHT=1

# Also patch EOF byte after header edit.
HEX_HEADER_EOF_PATCH_ENABLED=true
HEX_HEADER_EOF_BYTE=21

# Backup originals and restrict default file types.
HEX_HEADER_BACKUP_ENABLED=true
HEX_HEADER_EXTENSIONS=.gif
